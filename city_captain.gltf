
// Era Dominion premium leader model pack v22
// Builds Zelda-like casual fantasy leaders from modular Three.js meshes.
// Neutral citizens and followers should stay lightweight; only player/enemy leaders use this.
window.EraPremiumLeaders = (function(){
  const C = {
    skin: 0xf0c7a0, skin2: 0xdca97c, hair: 0x2b1a12, dark: 0x15171c,
    leather: 0x5a321e, belt: 0x2b1c13, steel: 0xbfc7d5, steelDark:0x6e7685,
    blue:0x1d63d8, blue2:0x0c3f91, purple:0x6d2ab8, red:0x9f1c18,
    gold:0xd6a322, gold2:0xffdf65, white:0xf1ead8, black:0x101015
  };
  function mat(c, rough=.48, metal=.08, emissive=0, ei=0){
    return new THREE.MeshStandardMaterial({color:c, roughness:rough, metalness:metal, emissive:emissive, emissiveIntensity:ei});
  }
  function add(g, mesh, x=0,y=0,z=0, rx=0,ry=0,rz=0){
    mesh.position.set(x,y,z); mesh.rotation.set(rx,ry,rz); mesh.castShadow=true; mesh.receiveShadow=true; g.add(mesh); return mesh;
  }
  function sphere(r, c, sx=1, sy=1, sz=1, seg=22){
    const m = new THREE.Mesh(new THREE.SphereGeometry(r,seg,seg), mat(c));
    m.scale.set(sx,sy,sz); return m;
  }
  function cyl(r1,r2,h,c,seg=14){
    return new THREE.Mesh(new THREE.CylinderGeometry(r1,r2,h,seg), mat(c));
  }
  function box(w,h,d,c){
    return new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat(c));
  }
  function cone(r,h,c,seg=5){
    return new THREE.Mesh(new THREE.ConeGeometry(r,h,seg), mat(c));
  }
  function capsuleLike(g, c, y, height, radius, x=0,z=0){
    const body=cyl(radius*.92,radius,height,c,18); add(g, body, x,y,z);
    add(g, sphere(radius,c,1,0.55,1,18), x,y+height/2,z);
    add(g, sphere(radius*.92,c,1,0.45,1,18), x,y-height/2,z);
    return body;
  }
  function makeFace(g){
    add(g, sphere(.62,C.skin,0.93,1.06,.88,28), 0,3.58,.03);
    add(g, sphere(.17,C.skin2,1,.8,.85,16), 0,3.45,.57);
    add(g, sphere(.045,0x111111,1,1,1,8), -.21,3.62,.58);
    add(g, sphere(.045,0x111111,1,1,1,8), .21,3.62,.58);
    add(g, box(.32,.035,.035,0x27130c), 0,3.36,.62);
    add(g, sphere(.27,C.hair,1.4,.45,1,18), 0,4.08,.02);
    for(let i=-2;i<=2;i++){
      add(g, cone(.09,.42,C.hair,8), i*.15,3.98,.45, Math.PI*.86, 0, 0);
    }
    add(g, sphere(.15,C.skin,0.8,1,0.6,12), -.58,3.55,.02);
    add(g, sphere(.15,C.skin,0.8,1,0.6,12), .58,3.55,.02);
  }
  function makeLimbs(g, outfit, tier, walk=0){
    const sleeve = outfit.main, glove = tier>=2 ? C.steelDark : C.skin;
    const boot = tier>=2 ? C.steelDark : 0x20150f;
    const armSwing = Math.sin(walk)*0.22;
    for(const side of [-1,1]){
      add(g, cyl(.16,.20,.96,sleeve,14), side*.68,2.42,.03, .18+side*0,0, side*(.25+armSwing));
      add(g, cyl(.13,.15,.62,glove,12), side*.78,1.86,.02, .05,0, side*.1);
      add(g, sphere(.17,C.skin,1,1,1,12), side*.82,1.48,.03);
      add(g, cyl(.18,.22,.96,outfit.leg,14), side*.28,.92,.0, side*0.06,0,side*.04);
      add(g, cyl(.17,.20,.62,boot,12), side*.28,.33,.04);
      add(g, box(.35,.16,.54,boot), side*.28,.03,.14);
    }
  }
  function makeTorso(g,outfit,tier){
    // chest built from tapered cylinders/spheres instead of box body
    add(g, cyl(.45,.58,1.15,outfit.main,24), 0,2.34,0);
    add(g, sphere(.56,outfit.main,1.05,.35,.72,20), 0,2.95,.02);
    add(g, cyl(.50,.62,.22,outfit.trim,20), 0,2.02,.02);
    add(g, box(1.12,.16,.16,outfit.trim),0,2.48,.49);
    add(g, box(.18,.78,.13,outfit.trim),-.26,2.47,.53);
    add(g, box(.18,.78,.13,outfit.trim),.26,2.47,.53);
    add(g, cyl(.33,.35,.45,outfit.leg,18),0,1.58,.0);
    add(g, box(1.08,.18,.2,C.belt),0,1.92,.02);
    add(g, box(.28,.23,.08,outfit.trim),0,1.92,.54);
    if(tier>=2){
      for(const side of [-1,1]){
        add(g, sphere(.32,outfit.trim,1.45,.38,.9,16),side*.56,2.95,.02,0,0,side*.12);
      }
    }
  }
  function makeCape(g,outfit,tier){
    if(tier<2) return;
    const len = tier>=5?2.7:tier>=4?2.25:tier>=3?1.9:1.45;
    const w = tier>=5?1.65:tier>=4?1.38:1.05;
    const cape = new THREE.Mesh(new THREE.BoxGeometry(w,len,.08), mat(outfit.cape,.55,.04));
    cape.geometry.translate(0,-len/2,0);
    add(g,cape,0,2.86,-.48, -0.18,0,0);
    add(g, box(w*.7,.12,.11,outfit.trim),0,2.88,-.42);
    if(tier>=4){
      add(g, sphere(.28,0xe8e2d3,1.15,.55,.75,16),-.5,3.05,-.25);
      add(g, sphere(.28,0xe8e2d3,1.15,.55,.75,16),.5,3.05,-.25);
    }
  }
  function makeGear(g,outfit,tier){
    if(tier>=2){
      const sword = new THREE.Group();
      add(sword, box(.09,1.25,.08,C.steel),0,.52,0);
      add(sword, cone(.12,.38,C.steel,4),0,1.33,0,0,Math.PI/4,0);
      add(sword, box(.42,.08,.08,outfit.trim),0,-.08,0);
      add(sword, cyl(.05,.05,.38,C.leather,8),0,-.28,0);
      sword.position.set(.92,1.65,.32); sword.rotation.z=-.55; sword.rotation.x=.15; g.add(sword);
      const shield = new THREE.Group();
      add(shield, new THREE.Mesh(new THREE.CylinderGeometry(.42,.42,.12,32), mat(outfit.main,.42,.15)),0,0,0,Math.PI/2,0,0);
      add(shield, new THREE.Mesh(new THREE.CylinderGeometry(.32,.32,.13,32), mat(outfit.trim,.35,.35)),0,0,.01,Math.PI/2,0,0);
      shield.position.set(-.92,1.93,.34); shield.rotation.z=.2; g.add(shield);
    }
    if(tier>=3){
      const helm = new THREE.Group();
      add(helm, sphere(.47,outfit.trim,1.05,.36,.85,20),0,0,0);
      add(helm, cone(.18,.55,outfit.trim,8),-.42,.05,0,0,0,.65);
      add(helm, cone(.18,.55,outfit.trim,8),.42,.05,0,0,0,-.65);
      helm.position.set(0,4.06,.02); g.add(helm);
    }
    if(tier>=4){
      for(let i=0;i<5;i++){
        add(g, cone(.09,.42,outfit.trim,6), (i-2)*.18,4.36,.02,0,0,0);
      }
    }
    if(tier>=5){
      const crownColor = tier>=6 ? C.gold2 : C.gold;
      add(g, cyl(.42,.46,.16,crownColor,24),0,4.16,.02);
      for(let i=0;i<7;i++){
        const a=(i/7)*Math.PI*2;
        add(g, cone(.07,.36,crownColor,5),Math.cos(a)*.35,4.39,Math.sin(a)*.22+.02);
      }
      add(g, sphere(.055,0x64e9ff,1,1,1,10),0,4.62,.02);
    }
  }
  function outfitFor(tier, color){
    const map = [
      null,
      {main:0x5d6a76, leg:0x2a2d32, trim:0x2f8cff, cape:0x1c3e73},
      {main:0x1858b7, leg:0x22304a, trim:0xd8a72f, cape:0x0a3c92},
      {main:0x58208f, leg:0x21172c, trim:0xc8a9ff, cape:0x35115f},
      {main:0x8f1d17, leg:0x231111, trim:0xe2b54a, cape:0x65110f},
      {main:0x161a24, leg:0x141414, trim:0xffd65a, cape:0x0d1738},
      {main:0xe8dfc8, leg:0x2a241a, trim:0xffd86b, cape:0xf5f0df}
    ];
    const o = map[Math.max(1,Math.min(6,tier))];
    if(color && tier<=2){ o.main = color; }
    return {...o};
  }
  function makePremiumLeader(tier=1, color=0x2f8cff){
    const root = new THREE.Group();
    root.userData.isPremiumLeader = true;
    const scale = 1 + (tier-1)*0.055;
    root.scale.setScalar(scale);
    const outfit = outfitFor(tier,color);
    makeTorso(root,outfit,tier);
    makeFace(root);
    makeLimbs(root,outfit,tier,0);
    makeCape(root,outfit,tier);
    makeGear(root,outfit,tier);
    if(tier>=6){
      const aura = new THREE.Mesh(new THREE.TorusGeometry(1.15,.035,8,54), new THREE.MeshBasicMaterial({color:0xffe28a,transparent:true,opacity:.55}));
      aura.rotation.x=Math.PI/2; aura.position.y=.04; root.add(aura);
      const halo = new THREE.Mesh(new THREE.TorusGeometry(.78,.035,8,54), new THREE.MeshBasicMaterial({color:0xffe28a,transparent:true,opacity:.7}));
      halo.position.y=4.72; root.add(halo);
    }
    return root;
  }
  return { makePremiumLeader };
})();
